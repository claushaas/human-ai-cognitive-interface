{
	"author": "claus_haas",
	"dependencies": {
		"@react-router/cloudflare": "^7.13.1",
		"@react-router/fs-routes": "^7.13.1",
		"@react-router/node": "^7.13.1",
		"isbot": "^5.1.36",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.13.1"
	},
	"description": "Human-AI Cognitive Interface - Web Application (React Router v7 + Cloudflare Workers)",
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@cloudflare/workers-types": "^4.20260316.1",
		"@react-router/dev": "7.13.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vite-tsconfig-paths": "^6.1.1",
		"wrangler": "^4.74.0"
	},
	"name": "human-ai-cognitive-interface",
	"private": true,
	"scripts": {
		"biome": "biome check --unsafe --write",
		"build": "react-router build",
		"cf-typegen": "wrangler types",
		"clean": "rm -rf .react-router build dist",
		"deploy": "wrangler deploy",
		"dev": "react-router dev",
		"lint": "biome check --unsafe --write .",
		"postinstall": "pnpm run cf-typegen",
		"start": "wrangler dev",
		"typecheck": "pnpm run cf-typegen && react-router typegen && tsc -b",
		"typecheck:ci": "pnpm tsc -b",
		"update": "pnpm dlx npm-check-updates -i"
	},
	"type": "module"
}