{
	"author": "claus_haas",
	"description": "Human-AI Cognitive Interface - Monorepo",
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"turbo": "^2.8.17",
		"typescript": "^5.9.3"
	},
	"license": "MIT",
	"name": "human-ai-cognitive-interface",
	"packageManager": "pnpm@10.32.1",
	"private": true,
	"scripts": {
		"biome": "biome check --unsafe --write",
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"clean": "turbo run clean && rm -rf node_modules",
		"dev": "turbo run dev",
		"test": "turbo run test",
		"update": "pnpm dlx npm-check-updates -i"
	}
}