{
	"dependencies": {
		"@clhaas/palette-kit": "^0.4.0",
		"isbot": "^5.1.40",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-router": "^7.15.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@cloudflare/vite-plugin": "^1.36.0",
		"@react-router/dev": "^7.15.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^25",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/ui": "^4.1.5",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"playwright": "^1.59.1",
		"tailwindcss": "^4.2.4",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"wrangler": "^4.88.0"
	},
	"name": "haci",
	"private": true,
	"scripts": {
		"biome:check": "biome check .",
		"biome:fix": "biome check --write --unsafe .",
		"build": "react-router build",
		"cf-typegen": "wrangler types",
		"deploy": "npm run build && wrangler deploy",
		"dev": "react-router dev",
		"postinstall": "npm run cf-typegen",
		"preview": "npm run build && vite preview",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:watch": "vitest",
		"typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
		"update": "pnpm dlx npm-check-updates -i",
		"validate": "pnpm typecheck && pnpm biome:check && pnpm test && pnpm build"
	},
	"type": "module"
}
