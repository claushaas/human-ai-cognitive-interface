{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "haci",
  "compatibility_date": "2025-04-04",
  "main": "./workers/app.ts",
  "vars": {
    "VALUE_FROM_CLOUDFLARE": "Hello from Cloudflare"
  },
  "d1_databases": [
    {
      "binding": "HACI_DB",
      "database_name": "haci-local",
      "database_id": "local"
    }
  ]
}
