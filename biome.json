{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on",
				"useSortedAttributes": "on",
				"useSortedKeys": "on",
				"useSortedProperties": "on"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**/*.js",
			"**/*.ts",
			"**/*.tsx",
			"**/*.css",
			"**/*.scss",
			"**/*.html",
			"**/*.json",
			"**/*.md",
			"!**/node_modules",
			"!**/dist",
			"!**/build",
			"!**/coverage",
			"!**/.git/",
			"!**/.vscode",
			"!**/.react-router",
			"!**/*.d.ts",
			"!**/*.spec.ts",
			"!**/.github",
			"!**/.rnstorybook"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"linter": {
		"domains": {
			"react": "all"
		},
		"enabled": true,
		"rules": {
			"performance": {
				"noDynamicNamespaceImportAccess": "off"
			},
			"recommended": true
		}
	},
	"overrides": [
		{
			"includes": ["app/root.tsx", "app/routes/home.tsx", "app/welcome/*.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"noSvgWithoutTitle": "off"
					},
					"correctness": {
						"noEmptyPattern": "off"
					},
					"style": {
						"useComponentExportOnlyModules": "off"
					}
				}
			}
		}
	],
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"useIgnoreFile": true
	}
}
