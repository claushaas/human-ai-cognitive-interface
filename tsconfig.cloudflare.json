{
	"compilerOptions": {
		"baseUrl": ".",
		"composite": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"module": "ES2022",
		"moduleResolution": "bundler",
		"paths": {
			"~/*": ["./app/*"],
			"~/config/*": ["./config/*"],
			"~/core/*": ["./core/*"],
			"~/db": ["./db/index.ts"],
			"~/types": ["./types/index.ts"],
			"~/types/*": ["./types/*"]
		},
		"resolveJsonModule": true,
		"rootDirs": [".", "./.react-router/types"],
		"strict": true,
		"target": "ES2022",
		"types": ["vite/client"]
	},
	"exclude": ["workers/**/*"],
	"extends": "./tsconfig.json",
	"include": [
		".react-router/types/**/*",
		"app/**/*",
		"app/**/.server/**/*",
		"app/**/.client/**/*",
		"core/**/*",
		"db/**/*",
		"types/**/*",
		"worker-configuration.d.ts"
	]
}
